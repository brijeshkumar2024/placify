# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/campus_placement?retryWrites=true&w=majority&appName=<AppName>

# JWT - must be the SAME secret across ALL 5 services (base64-encoded, min 32 bytes)
JWT_SECRET=replace-with-shared-base64-encoded-secret

# Cloudinary (for student profile photo uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
