# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/campus_placement?retryWrites=true&w=majority&appName=<AppName>

# JWT - must be the SAME secret across ALL 5 services (base64-encoded, min 32 bytes)
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-shared-base64-encoded-secret
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
JWT_RESET_EXPIRATION=900000

# Brevo SMTP (for OTP + verification emails)
BREVO_SMTP_LOGIN=your-smtp-login@smtp-brevo.com
BREVO_SMTP_PASSWORD=your-brevo-smtp-key
BREVO_FROM_EMAIL=verified-sender@example.com

# Frontend URL for password reset link in email
RESET_FRONTEND_BASE_URL=http://localhost:5173/reset-password

# Redis (for OTP storage) - use Upstash for cloud/production
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
