# -----------------------------------------------------------------------------
# Campus Placement Portal - Monorepo Ignore Rules (Node + Java + Python)
# -----------------------------------------------------------------------------

# OS / Editor
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*.tmp
*.bak
*.orig
.idea/
*.iml

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-workspace

# -----------------------------------------------------------------------------
# Secrets and environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env
*.pem
*.key
*.crt

# Logs
*.log
logs/
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Node.js / Frontend / Gateway services
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
.npm/
.pnpm-store/
.yarn/

dist/
build/
.next/
.nuxt/
.svelte-kit/
.vite/
coverage/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Java / Maven / Spring Boot
# -----------------------------------------------------------------------------
target/
**/target/
.mvn/
dependency-reduced-pom.xml

*.class
*.jar
*.war
*.ear

# Java test and profiling outputs
hs_err_pid*
replay_pid*

# -----------------------------------------------------------------------------
# Python / AI services
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
.python-version

.venv/
venv/
env/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

*.egg-info/
.eggs/
pip-wheel-metadata/

# Common ML artifacts
*.pkl
*.joblib
*.h5
*.onnx

# -----------------------------------------------------------------------------
# Project build outputs and temporary folders
# -----------------------------------------------------------------------------
out/
tmp/
temp/
uploads/
pdfs/
